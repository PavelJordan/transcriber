# Python env (huge, machine-specific — rebuild from requirements)
.venv/
__pycache__/
*.pyc

# Raw recordings — large and private; audio must never leave the device
*.mp4
*.mkv
*.wav
*.m4a

# Transcript outputs (transcribe.py) — private meeting content, never commit.
# Real consultation samples live outside this repo. `git add -f` if you ever
# genuinely need a .txt tracked.
*.txt
*.srt
*.vtt
transcribe.log

# Local-only harness settings (bypass mode, personal allow rules)
.claude/settings.local.json

# Sidecar binaries — platform-specific, built/fetched locally or by CI.
# The release workflow (.github/workflows/release.yml) is the source of truth; for
# local dev produce both for your <target-triple> (e.g. x86_64-unknown-linux-gnu):
#   whisper-cli: clone ggml-org/whisper.cpp, cmake -DBUILD_SHARED_LIBS=OFF
#     -DGGML_NATIVE=OFF, build whisper-cli → binaries/whisper-cli-<triple>
#   ffmpeg: grab a static build (Linux: johnvansickle.com; Win/Mac: BtbN/evermeet)
#     → binaries/ffmpeg-<triple>
app/src-tauri/binaries/

# Tauri / Node build output
node_modules/
app/src-tauri/target/
dist/
build/
