# Python env (huge, machine-specific — rebuild from requirements)
.venv/
__pycache__/
*.pyc

# Raw recordings — large and private; audio must never leave the device
*.mp4
*.mkv
*.wav
*.m4a

# Transcript outputs (transcribe.py) — private meeting content, never commit.
# Real consultation samples live outside this repo. `git add -f` if you ever
# genuinely need a .txt tracked.
*.txt
*.srt
*.vtt
transcribe.log

# Local-only harness settings (bypass mode, personal allow rules)
.claude/settings.local.json

# Tauri / Node build output (ready for when app/ exists)
node_modules/
app/src-tauri/target/
dist/
build/
